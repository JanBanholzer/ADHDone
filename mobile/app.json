{
  "expo": {
    "name": "ADHDone",
    "slug": "adhdone",
    "version": "1.0.0",
    "scheme": "adhdone",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adhdone.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F2F2F7"
      },
      "package": "com.adhdone.app"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "ADHDone needs calendar access to sync your events with tasks and include them in daily briefings.",
          "remindersPermission": false
        }
      ]
    ]
  }
}
